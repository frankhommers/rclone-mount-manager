<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RcloneMountManager.ViewModels"
        xmlns:views="using:RcloneMountManager.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="760"
        x:Class="RcloneMountManager.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Rclone Mount Manager"
        MinWidth="980"
        MinHeight="680"
        Width="1200"
        Height="760">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="CornerRadius" Value="9"/>
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
    </Window.Styles>

    <Border Margin="14"
            CornerRadius="20"
            Background="{DynamicResource SystemControlPageBackgroundChromeLowBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="1"
            Padding="1"
            BoxShadow="0 14 32 0 #330B121A">
        <Grid RowDefinitions="*,Auto">

            <Grid Grid.Row="0" ColumnDefinitions="300,Auto,*">

                <Border Grid.Column="0"
                        CornerRadius="20,0,0,0"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                    <Grid RowDefinitions="Auto,*,Auto">
                        <Border Grid.Row="0" Padding="16,16,16,8">
                            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Library" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="Remotes and mounts"
                                           FontSize="12"
                                           Opacity="0.75"
                                           Margin="0,2,0,0"/>
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="1"
                                      Margin="8,0"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*,Auto" Margin="4,2,4,0">
                                    <TextBlock Text="REMOTES" FontSize="11" FontWeight="SemiBold" Opacity="0.75" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1"
                                            Content="Add remote"
                                            Command="{Binding AddRemoteCommand}"
                                            ToolTip.Tip="Create a remote entry"
                                            Padding="10,4"
                                            FontSize="11"/>
                                </Grid>
                                <ListBox ItemsSource="{Binding RemoteProfiles}"
                                         SelectedItem="{Binding SelectedRemoteProfile}"
                                         IsVisible="{Binding HasRemoteProfiles}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="4,4,4,6" Spacing="2">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Source}" FontSize="11" Opacity="0.75" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock Text="No remotes yet. Add a mount and set type to rclone."
                                           IsVisible="{Binding !HasRemoteProfiles}"
                                           Margin="8,0,8,2"
                                           FontSize="11"
                                           Opacity="0.65"
                                           TextWrapping="Wrap"/>

                                <Grid ColumnDefinitions="*,Auto" Margin="4,8,4,0">
                                    <TextBlock Text="MOUNTS" FontSize="11" FontWeight="SemiBold" Opacity="0.75" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1"
                                            Content="Add mount"
                                            Command="{Binding AddProfileCommand}"
                                            ToolTip.Tip="Create a new mount profile"
                                            Padding="10,4"
                                            FontSize="11"/>
                                </Grid>
                                <ListBox ItemsSource="{Binding MountProfiles}"
                                         SelectedItem="{Binding SelectedMountProfile}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="4,4,4,6" Spacing="2">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Type}" FontSize="11" Opacity="0.75"/>
                                                <TextBlock Text="{Binding MountPoint}" FontSize="11" Opacity="0.65" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Row="2"
                                Padding="12"
                                CornerRadius="0,0,0,20"
                                BorderThickness="0,1,0,0"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                            <StackPanel Spacing="6">
                                <Button Content="Remove"
                                        Command="{Binding RemoveProfileCommand}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"/>
                                <Button Content="Refresh status"
                                        Command="{Binding RefreshStatusCommand}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Width="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}"/>

                <Grid Grid.Column="2" RowDefinitions="Auto,*">
                    <Border Grid.Row="0"
                            Padding="24,18"
                            CornerRadius="0,20,0,0"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel>
                                <TextBlock Text="{Binding WorkspaceTitle}" FontSize="20" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding WorkspaceSubtitle}"
                                           FontSize="12"
                                           Opacity="0.75"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="Theme" VerticalAlignment="Center"/>
                                <ComboBox Width="140" ItemsSource="{Binding ThemeModes}" SelectedItem="{Binding SelectedThemeMode}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1">
                        <StackPanel Margin="20,14" Spacing="10">

                            <StackPanel IsVisible="{Binding ShowRemoteEditor}" Spacing="10">

                            <!-- Backend Configuration -->
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Backend Configuration" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="Reload types"
                                        Command="{Binding RefreshBackendsCommand}"
                                        Padding="8,2" FontSize="11"/>
                            </Grid>
                            <TextBlock Text="Build any rclone remote type directly from this app." FontSize="11" Opacity="0.6" Margin="0,-6,0,0"/>

                            <Grid ColumnDefinitions="200,*">
                                <TextBlock Text="Backend type" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableBackends}" SelectedItem="{Binding SelectedBackend}" HorizontalAlignment="Stretch" Margin="8,0,0,0">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>
                            <TextBlock Text="{Binding SelectedBackendDescription}" TextWrapping="Wrap" FontSize="11" Opacity="0.6" Margin="0,-6,0,0"/>

                            <Grid ColumnDefinitions="200,*">
                                <TextBlock Text="Remote name" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding NewRemoteName}" Watermark="example: my-webdav" HorizontalAlignment="Stretch" Margin="8,0,0,0"/>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding BackendOptionInputs}"
                                          IsVisible="{Binding HasBackendOptions}"
                                          ItemTemplate="{DynamicResource BackendOptionTemplateSelector}"/>

                            <TextBlock Text="No configurable options for this backend type."
                                       FontSize="11" Opacity="0.6"
                                       IsVisible="{Binding !HasBackendOptions}"/>

                            <Expander IsVisible="{Binding HasAdvancedBackendOptions}"
                                      IsExpanded="{Binding ShowAdvancedBackendOptions}"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Stretch"
                                      Margin="0,4,0,0">
                                <Expander.Header>
                                    <TextBlock Text="Advanced options" FontWeight="SemiBold"/>
                                </Expander.Header>
                                <ItemsControl ItemsSource="{Binding AdvancedBackendOptionInputs}"
                                              Margin="0,4,0,0"
                                              ItemTemplate="{DynamicResource BackendOptionTemplateSelector}"/>
                            </Expander>

                            <Button Content="Create remote and use in selected profile"
                                    Command="{Binding CreateRemoteCommand}"
                                    HorizontalAlignment="Left"/>

                            </StackPanel>

                            <StackPanel IsVisible="{Binding !ShowRemoteEditor}" Spacing="10">

                            <Separator Margin="0,4"/>

                            <!-- Profile Settings -->
                            <TextBlock Text="Profile Settings" FontWeight="SemiBold" FontSize="14"/>

                            <Grid ColumnDefinitions="200,*">
                                <TextBlock Text="Profile name" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding SelectedProfile.Name}" HorizontalAlignment="Stretch" Margin="8,0,0,0"/>
                            </Grid>

                            <Grid ColumnDefinitions="200,*">
                                <TextBlock Text="Mount type" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1" ItemsSource="{Binding MountTypes}" SelectedItem="{Binding SelectedProfile.Type}" HorizontalAlignment="Stretch" Margin="8,0,0,0">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>

                            <Grid ColumnDefinitions="200,*">
                                <TextBlock Text="Remote" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding RemoteProfiles}"
                                          SelectedItem="{Binding SelectedMountRemoteProfile}"
                                          Margin="8,0,0,0"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="{Binding !ShowRemoteEditor}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>
                            <TextBlock Text="Choose a remote for this mount, or create one in REMOTES first."
                                       FontSize="11"
                                       Opacity="0.6"
                                       Margin="0,-6,0,0"/>

                            <Grid ColumnDefinitions="200,*">
                                <TextBlock Text="{Binding SourceLabel}" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding SelectedProfile.Source}" Watermark="{Binding SourceHint}" HorizontalAlignment="Stretch" Margin="8,0,0,0"/>
                            </Grid>
                            <TextBlock Text="{Binding SourceFormatHelp}" TextWrapping="Wrap" FontSize="11" Opacity="0.6" Margin="0,-6,0,0"/>

                            <Grid ColumnDefinitions="200,*">
                                <TextBlock Text="Local mount path" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding SelectedProfile.MountPoint}" Watermark="{Binding MountPointHint}" HorizontalAlignment="Stretch" Margin="8,0,0,0"/>
                            </Grid>

                            <Grid ColumnDefinitions="200,*">
                                <TextBlock Text="Rclone binary path" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding SelectedProfile.RcloneBinaryPath}" Watermark="Default: rclone" HorizontalAlignment="Stretch" Margin="8,0,0,0"/>
                            </Grid>

                             <CheckBox Content="UNSECURE: include plaintext passwords in generated script"
                                       IsChecked="{Binding SelectedProfile.AllowInsecurePasswordsInScript}"/>

                             <Border BorderThickness="1"
                                     BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                     CornerRadius="10"
                                     Padding="10"
                                     Margin="0,-2,0,0">
                                 <StackPanel Spacing="6">
                                     <TextBlock Text="Reliability"
                                                FontWeight="SemiBold"/>
                                     <Grid ColumnDefinitions="200,*,Auto"
                                           ColumnSpacing="8">
                                         <TextBlock Text="Policy preset"
                                                    VerticalAlignment="Center"/>
                                         <ComboBox Grid.Column="1"
                                                   ItemsSource="{Binding ReliabilityPresets}"
                                                   SelectedValue="{Binding SelectedReliabilityPresetId}"
                                                   SelectedValueBinding="{Binding Id}">
                                             <ComboBox.ItemTemplate>
                                                 <DataTemplate>
                                                     <TextBlock Text="{Binding DisplayName}"/>
                                                 </DataTemplate>
                                             </ComboBox.ItemTemplate>
                                         </ComboBox>
                                         <Button Grid.Column="2"
                                                 Content="Apply"
                                                 Command="{Binding ApplyReliabilityPresetCommand}"/>
                                     </Grid>
                                     <TextBlock Text="Applies managed reliability flags safely for this profile without editing raw options."
                                                FontSize="11"
                                                Opacity="0.6"
                                                TextWrapping="Wrap"/>
                                 </StackPanel>
                             </Border>

                              <Separator Margin="0,4"/>

                             <Border BorderThickness="1"
                                     BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                     CornerRadius="10"
                                     Padding="10"
                                     Margin="0,-2,0,0">
                                 <StackPanel Spacing="6">
                                     <TextBlock Text="Runtime state" FontWeight="SemiBold"/>
                                     <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto">
                                         <TextBlock Text="Lifecycle" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
                                         <TextBlock Text="{Binding SelectedProfileLifecycleText}" Grid.Row="0" Grid.Column="1" FontWeight="SemiBold"/>
                                         <TextBlock Text="Health" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
                                         <TextBlock Text="{Binding SelectedProfileHealthText}" Grid.Row="1" Grid.Column="1" FontWeight="SemiBold"/>
                                     </Grid>
                                 </StackPanel>
                             </Border>

                             <!-- Mount Parameters -->
                             <views:MountOptionsView DataContext="{Binding MountOptionsVm}"/>

                            <Separator Margin="0,4"/>

                            <!-- Actions -->
                            <WrapPanel>
                                <Button Content="{Binding SaveChangesButtonText}" Command="{Binding SaveChangesCommand}" Margin="0,0,8,8"/>
                                <Button Content="Test connection" Command="{Binding TestConnectionCommand}" Margin="0,0,8,8"/>
                                <Button Content="Start mount" Command="{Binding StartMountCommand}" Margin="0,0,8,8"/>
                                <Button Content="Stop mount" Command="{Binding StopMountCommand}" Margin="0,0,8,8"/>
                                <Button Content="Generate script" Command="{Binding GenerateScriptCommand}" Margin="0,0,8,8"/>
                                <Button Content="Save script" Command="{Binding SaveScriptCommand}" Margin="0,0,8,8"/>
                                <Button Content="Run startup preflight"
                                        Command="{Binding RunStartupPreflightCommand}"
                                        IsVisible="{Binding IsStartupSupported}"
                                        Margin="0,0,8,8"/>
                                <Button Content="{Binding StartupButtonText}"
                                        Command="{Binding ToggleStartupCommand}"
                                        IsVisible="{Binding IsStartupSupported}"
                                        Margin="0,0,8,8"/>
                            </WrapPanel>

                            <Border IsVisible="{Binding IsStartupSupported}"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                    CornerRadius="10"
                                    Padding="10"
                                    Margin="0,-2,0,0">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Startup preflight" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding StartupPreflightSummary}" FontSize="11"/>
                                    <TextBox Text="{Binding StartupPreflightReport}"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             MinHeight="72"
                                             MaxHeight="160"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             FontFamily="Cascadia Mono, Consolas, Menlo"/>
                                </StackPanel>
                            </Border>

                            <Separator Margin="0,4"/>

                            <!-- Script Preview -->
                            <TextBlock Text="Script preview" FontWeight="SemiBold" FontSize="14"/>
                            <TextBox Text="{Binding GeneratedScript}"
                                     FontFamily="Cascadia Mono, Consolas, Menlo"
                                     AcceptsReturn="True"
                                     TextWrapping="NoWrap"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                     MinHeight="140"
                                     MaxHeight="220"/>

                            <!-- Diagnostics Timeline -->
                            <TextBlock Text="Diagnostics timeline" FontWeight="SemiBold" FontSize="14"/>
                            <Grid ColumnDefinitions="200,*,Auto" RowDefinitions="Auto,Auto" RowSpacing="6">
                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="Profile scope"
                                           VerticalAlignment="Center"/>
                                <ComboBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                                          Margin="8,0,0,0"
                                          ItemsSource="{Binding DiagnosticsProfileFilters}"
                                          SelectedValue="{Binding SelectedDiagnosticsProfileId}"
                                          SelectedValueBinding="{Binding ProfileId}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="Timeline scope"
                                           VerticalAlignment="Center"/>
                                <CheckBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                          Margin="8,0,0,0"
                                          Content="Startup path only"
                                          IsChecked="{Binding StartupTimelineOnly}"/>
                            </Grid>
                            <TextBlock Text="Use profile and startup filters to isolate startup failures quickly."
                                       FontSize="11"
                                       Opacity="0.6"
                                       Margin="0,-2,0,0"/>
                            <ListBox ItemsSource="{Binding DiagnosticsRows}"
                                     IsVisible="{Binding HasDiagnosticsRows}"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                     MinHeight="140"
                                     MaxHeight="220">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="170,90,180,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding TimestampText}"
                                                       FontFamily="Cascadia Mono, Consolas, Menlo"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding SeverityText}"
                                                       FontFamily="Cascadia Mono, Consolas, Menlo"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding StageText}"
                                                       FontFamily="Cascadia Mono, Consolas, Menlo"/>
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding MessageText}"
                                                       FontFamily="Cascadia Mono, Consolas, Menlo"
                                                       TextWrapping="Wrap"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Border IsVisible="{Binding !HasDiagnosticsRows}"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                    CornerRadius="8"
                                    Padding="10"
                                    MinHeight="72">
                                <TextBlock Text="{Binding DiagnosticsEmptyStateText}"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Opacity="0.75"/>
                            </Border>

                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <Border Grid.Row="1"
                    CornerRadius="0,0,20,20"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="16,8">
                <TextBlock Text="{Binding StatusText}" FontSize="12" VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</Window>
