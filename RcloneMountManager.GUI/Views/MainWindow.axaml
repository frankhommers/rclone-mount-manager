<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RcloneMountManager.ViewModels"
        xmlns:views="using:RcloneMountManager.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="760"
        x:Class="RcloneMountManager.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Rclone Mount Manager"
        MinWidth="980"
        MinHeight="680"
        Width="1200"
        Height="760">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="CornerRadius" Value="9"/>
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
    </Window.Styles>

    <Border Margin="14"
            CornerRadius="20"
            Background="{DynamicResource SystemControlPageBackgroundChromeLowBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="1"
            Padding="1"
            BoxShadow="0 14 32 0 #330B121A">
        <Grid RowDefinitions="*,Auto">

            <Grid Grid.Row="0" ColumnDefinitions="300,Auto,*">

                <Border Grid.Column="0"
                        CornerRadius="20,0,0,0"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                    <Grid RowDefinitions="Auto,*,Auto">
                        <Border Grid.Row="0" Padding="16,16,16,8">
                            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Profiles" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="Choose one profile"
                                           FontSize="12"
                                           Opacity="0.75"
                                           Margin="0,2,0,0"/>
                                <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                        Content="+"
                                        Command="{Binding AddProfileCommand}"
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Padding="8,4"/>
                            </Grid>
                        </Border>

                        <ListBox Grid.Row="1"
                                 Margin="8,0"
                                 ItemsSource="{Binding Profiles}"
                                 SelectedItem="{Binding SelectedProfile}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="4,4,4,6" Spacing="2">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Type}" FontSize="11" Opacity="0.75"/>
                                        <TextBlock Text="{Binding MountPoint}" FontSize="11" Opacity="0.65" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Grid.Row="2"
                                Padding="12"
                                CornerRadius="0,0,0,20"
                                BorderThickness="0,1,0,0"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                            <StackPanel Spacing="6">
                                <Button Content="Remove"
                                        Command="{Binding RemoveProfileCommand}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"/>
                                <Button Content="Refresh status"
                                        Command="{Binding RefreshStatusCommand}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Width="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}"/>

                <Grid Grid.Column="2" RowDefinitions="Auto,*">
                    <Border Grid.Row="0"
                            Padding="24,18"
                            CornerRadius="0,20,0,0"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel>
                                <TextBlock Text="Mount Assistant" FontSize="20" FontWeight="SemiBold"/>
                                <TextBlock Text="Preset -> credentials -> mount path -> Start mount"
                                           FontSize="12"
                                           Opacity="0.75"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="Theme" VerticalAlignment="Center"/>
                                <ComboBox Width="140" ItemsSource="{Binding ThemeModes}" SelectedItem="{Binding SelectedThemeMode}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" Padding="20,14">
                        <StackPanel>
                            <Border BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                                <StackPanel Spacing="8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Text="Advanced mode (all rclone backends)" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="Reload types" Command="{Binding RefreshBackendsCommand}"/>
                                    </Grid>
                                    <TextBlock Text="Build any rclone remote type directly from this app." FontSize="11" Opacity="0.75"/>

                                    <Grid ColumnDefinitions="220,*">
                                        <TextBlock Text="Backend type" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableBackends}" SelectedItem="{Binding SelectedBackend}" Margin="8,0,0,0" MaxWidth="480">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </Grid>
                                    <TextBlock Text="{Binding SelectedBackendDescription}" TextWrapping="Wrap" FontSize="11" Opacity="0.7"/>

                                    <Grid ColumnDefinitions="220,*">
                                        <TextBlock Text="Remote name" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" Text="{Binding NewRemoteName}" Watermark="example: my-webdav" Margin="8,0,0,0"/>
                                    </Grid>

                                    <CheckBox Content="Show advanced backend options" IsChecked="{Binding ShowAdvancedBackendOptions}"/>

                                    <ScrollViewer Height="180" IsVisible="{Binding HasBackendOptions}">
                                        <ItemsControl ItemsSource="{Binding BackendOptionInputs}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderThickness="0,0,0,1" Padding="0,6" Opacity="0.95">
                                                        <StackPanel Spacing="4">
                                                            <Grid ColumnDefinitions="220,*">
                                                                <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
                                                                <TextBox Grid.Column="1"
                                                                         Text="{Binding Value}"
                                                                         Margin="8,0,0,0"/>
                                                            </Grid>
                                                            <TextBlock Text="{Binding Help}" TextWrapping="Wrap" FontSize="11" Opacity="0.7"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <Button Content="Create remote and use in selected profile"
                                            Command="{Binding CreateRemoteCommand}"/>
                                </StackPanel>
                            </Border>

                            <Grid ColumnDefinitions="220,*" Margin="0,0,0,10">
                                <TextBlock Text="Profile name" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding SelectedProfile.Name}" Margin="8,0,0,0"/>
                            </Grid>

                            <Grid ColumnDefinitions="220,*" Margin="0,0,0,10">
                                <TextBlock Text="Mount type" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1" ItemsSource="{Binding MountTypes}" SelectedItem="{Binding SelectedProfile.Type}" Margin="8,0,0,0"/>
                            </Grid>

                            <Border BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                                <StackPanel Spacing="8">
                                    <Grid ColumnDefinitions="220,*">
                                        <TextBlock Text="{Binding SourceLabel}" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" Text="{Binding SelectedProfile.Source}" Watermark="{Binding SourceHint}" Margin="8,0,0,0"/>
                                    </Grid>
                                    <TextBlock Text="{Binding SourceFormatHelp}" TextWrapping="Wrap" Opacity="0.75"/>

                                    <Grid ColumnDefinitions="220,*">
                                        <TextBlock Text="Local mount path" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" Text="{Binding SelectedProfile.MountPoint}" Watermark="{Binding MountPointHint}" Margin="8,0,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Mount Parameters (typed options) -->
                            <Border BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                                <views:MountOptionsView DataContext="{Binding MountOptionsVm}"/>
                            </Border>

                            <WrapPanel Margin="0,0,0,8">
                                <Button Content="{Binding SaveChangesButtonText}" Command="{Binding SaveChangesCommand}" Margin="0,0,8,8"/>
                                <Button Content="Test connection" Command="{Binding TestConnectionCommand}" Margin="0,0,8,8"/>
                                <Button Content="Start mount" Command="{Binding StartMountCommand}" Margin="0,0,8,8"/>
                                <Button Content="Stop mount" Command="{Binding StopMountCommand}" Margin="0,0,8,8"/>
                                <Button Content="Generate script" Command="{Binding GenerateScriptCommand}" Margin="0,0,8,8"/>
                                <Button Content="Save script" Command="{Binding SaveScriptCommand}" Margin="0,0,8,8"/>
                                <Button Content="{Binding StartupButtonText}"
                                        Command="{Binding ToggleStartupCommand}"
                                        IsVisible="{Binding IsStartupSupported}"
                                        Margin="0,0,8,8"/>
                            </WrapPanel>

                            <CheckBox Content="Show advanced settings" IsChecked="{Binding ShowAdvanced}" Margin="0,0,0,8"/>
                            <Expander IsExpanded="{Binding ShowAdvanced}" Header="Advanced" Margin="0,0,0,10">
                                <StackPanel Spacing="8" Margin="0,8,0,0">
                                    <Grid ColumnDefinitions="220,*">
                                        <TextBlock Text="Extra options" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" Text="{Binding SelectedProfile.ExtraOptions}" Watermark="{Binding OptionsHint}" Margin="8,0,0,0"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="220,*">
                                        <TextBlock Text="Rclone binary path" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" Text="{Binding SelectedProfile.RcloneBinaryPath}" Watermark="Default: rclone" Margin="8,0,0,0"/>
                                    </Grid>
                                    <CheckBox Content="UNSECURE: include plaintext passwords in generated script"
                                              IsChecked="{Binding SelectedProfile.AllowInsecurePasswordsInScript}"/>
                                </StackPanel>
                            </Expander>

                            <Border Padding="10" BorderThickness="1" CornerRadius="6" Margin="0,0,0,10">
                                <Grid RowDefinitions="Auto,*">
                                    <TextBlock Text="Script preview (selected profile)" FontWeight="SemiBold"/>
                                    <TextBox Grid.Row="1"
                                             Margin="0,8,0,0"
                                             Text="{Binding GeneratedScript}"
                                             FontFamily="Cascadia Mono, Consolas, Menlo"
                                             AcceptsReturn="True"
                                             TextWrapping="NoWrap"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                             MinHeight="180"
                                             MaxHeight="260"/>
                                </Grid>
                            </Border>

                            <Border Padding="10" BorderThickness="1" CornerRadius="6" Margin="0,0,0,10">
                                <Grid RowDefinitions="Auto,*">
                                    <TextBlock Text="Activity (selected profile)" FontWeight="SemiBold"/>
                                    <ListBox Grid.Row="1"
                                             ItemsSource="{Binding Logs}"
                                             Margin="0,8,0,0"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                             MinHeight="180"
                                             MaxHeight="260">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding .}" FontFamily="Cascadia Mono, Consolas, Menlo"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <Border Grid.Row="1"
                    CornerRadius="0,0,20,20"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="16,8">
                <TextBlock Text="{Binding StatusText}" FontSize="12" VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</Window>
