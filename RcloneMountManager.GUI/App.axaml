<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="RcloneMountManager.App"
             xmlns:local="using:RcloneMountManager"
             xmlns:converters1="clr-namespace:RcloneMountManager.GUI.Converters"
             xmlns:gui="clr-namespace:RcloneMountManager.GUI"
             Name="Rclone Mount Manager"
             RequestedThemeVariant="Default">

    <Application.Resources>
        <converters1:BoolToBrushConverter x:Key="AccentBorderConverter"
                                         TrueBrush="{DynamicResource SystemAccentColorDark1}"
                                         FalseBrush="Transparent" />
        <converters1:BoolToFontWeightConverter x:Key="ModifiedFontWeightConverter" />
        <converters1:EnumDescriptionConverter x:Key="EnumDescriptionConverter" />
        <converters1:BoolToOpacityConverter x:Key="PinOpacityConverter"
                                           TrueOpacity="1.0"
                                           FalseOpacity="0.3" />

        <StreamGeometry x:Key="MdiFolderOutline">M20,18H4V8H20M20,6H12L10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6Z</StreamGeometry>
        <StreamGeometry x:Key="MdiCloudOutline">M6.5 20Q4.22 20 2.61 18.43 1 16.85 1 14.58 1 12.63 2.17 11.1 3.35 9.57 5.25 9.15 5.88 6.85 7.75 5.43 9.63 4 12 4 14.93 4 16.96 6.04 19 8.07 19 11 20.73 11.2 21.86 12.5 23 13.78 23 15.5 23 17.38 21.69 18.69 20.38 20 18.5 20M6.5 18H18.5Q19.55 18 20.27 17.27 21 16.55 21 15.5 21 14.45 20.27 13.73 19.55 13 18.5 13H17V11Q17 8.93 15.54 7.46 14.08 6 12 6 9.93 6 8.46 7.46 7 8.93 7 11H6.5Q5.05 11 4.03 12.03 3 13.05 3 14.5 3 15.95 4.03 17 5.05 18 6.5 18M12 12Z</StreamGeometry>
        <StreamGeometry x:Key="MdiCogOutline">M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.04 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.04 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z</StreamGeometry>
        <StreamGeometry x:Key="MdiGauge">M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12C20,14.4 19,16.5 17.3,18C15.9,16.7 14,16 12,16C10,16 8.2,16.7 6.7,18C5,16.5 4,14.4 4,12A8,8 0 0,1 12,4M14,6A1,1 0 0,0 13,7A1,1 0 0,0 14,8A1,1 0 0,0 15,7A1,1 0 0,0 14,6M10,6A1,1 0 0,0 9,7A1,1 0 0,0 10,8A1,1 0 0,0 11,7A1,1 0 0,0 10,6M17,9A1,1 0 0,0 16,10A1,1 0 0,0 17,11A1,1 0 0,0 18,10A1,1 0 0,0 17,9M7,9A1,1 0 0,0 6,10A1,1 0 0,0 7,11A1,1 0 0,0 8,10A1,1 0 0,0 7,9M12,10A2,2 0 0,0 10,12A2,2 0 0,0 12,14A2,2 0 0,0 14,12A2,2 0 0,0 12,10Z</StreamGeometry>

        <DataTemplate x:Key="Toggle" x:CompileBindings="False">
            <Grid ColumnDefinitions="200,*,Auto" RowDefinitions="Auto,Auto" Margin="0,2">
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{Binding Label}"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Top"
                           Margin="0,6,0,0"
                           FontSize="12"
                           FontWeight="{Binding ShouldInclude, Converter={StaticResource ModifiedFontWeightConverter}}" />
                <ToggleSwitch Grid.Row="0" Grid.Column="1"
                              IsChecked="{Binding BoolValue}"
                              OnContent="Enabled" OffContent="Disabled"
                              Margin="8,0,0,0" />
                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Spacing="2" Margin="4,0,0,0">
                    <Button Command="{Binding TogglePinCommand}"
                            Padding="6,4"
                            ToolTip.Tip="Pin to always include in script">
                        <Panel>
                            <PathIcon Data="M16,12V4H17V2H7V4H8V12L6,14V16H11.2V22H12.8V16H18V14L16,12Z"
                                      Width="12" Height="12"
                                      IsVisible="{Binding IsPinned}" />
                            <PathIcon
                                Data="M2,5.27L3.28,4L20,20.72L18.73,22L12.8,16.07V22H11.2V16H6V14L8,12V11.27L2,5.27M16,12L18,14V16H17.82L8,6.18V4H7V2H17V4H16V12Z"
                                Width="12" Height="12"
                                IsVisible="{Binding !IsPinned}"
                                Opacity="0.4" />
                        </Panel>
                    </Button>
                    <Button Command="{Binding ResetToDefaultCommand}"
                            Padding="6,4"
                            Opacity="{Binding ShouldInclude, Converter={StaticResource PinOpacityConverter}}"
                            IsHitTestVisible="{Binding ShouldInclude}"
                            ToolTip.Tip="{Binding DefaultStr, StringFormat='Reset to default ({0})'}">
                        <PathIcon Data="M17.65 6.35A8 8 0 1 0 20 12h-2a6 6 0 1 1-1.76-4.24L13 11h7V4l-2.35 2.35z"
                                  Width="12" Height="12" />
                    </Button>
                </StackPanel>
                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                           Text="{Binding Help}" TextWrapping="Wrap"
                           FontSize="11" Opacity="0.5" FontStyle="Italic"
                           Margin="0,2,0,4"
                           MaxLines="2" TextTrimming="CharacterEllipsis"
                           ToolTip.Tip="{Binding Help}" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ComboBox" x:CompileBindings="False">
            <Grid ColumnDefinitions="200,*,Auto" RowDefinitions="Auto,Auto" Margin="0,2">
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{Binding Label}"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"
                           IsVisible="{Binding !IsPassword}"
                           FontSize="12"
                           FontWeight="{Binding ShouldInclude, Converter={StaticResource ModifiedFontWeightConverter}}" />
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{Binding Label}"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Top"
                           IsVisible="{Binding IsPassword}"
                           FontSize="12"
                           FontWeight="{Binding ShouldInclude, Converter={StaticResource ModifiedFontWeightConverter}}" />
                <ComboBox Grid.Row="0" Grid.Column="1"
                          ItemsSource="{Binding EnumValues}"
                          SelectedItem="{Binding SelectedEnumValue}"
                          PlaceholderText="{Binding DefaultStr}"
                          Margin="8,0,0,0"
                          MinWidth="200"
                          MaxDropDownHeight="300"
                          HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" MaxWidth="500"
                                       ToolTip.Tip="{Binding}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Spacing="2" Margin="4,0,0,0">
                    <Button Command="{Binding TogglePinCommand}"
                            Padding="6,4"
                            ToolTip.Tip="Pin to always include in script">
                        <Panel>
                            <PathIcon Data="M16,12V4H17V2H7V4H8V12L6,14V16H11.2V22H12.8V16H18V14L16,12Z"
                                      Width="12" Height="12"
                                      IsVisible="{Binding IsPinned}" />
                            <PathIcon
                                Data="M2,5.27L3.28,4L20,20.72L18.73,22L12.8,16.07V22H11.2V16H6V14L8,12V11.27L2,5.27M16,12L18,14V16H17.82L8,6.18V4H7V2H17V4H16V12Z"
                                Width="12" Height="12"
                                IsVisible="{Binding !IsPinned}"
                                Opacity="0.4" />
                        </Panel>
                    </Button>
                    <Button Command="{Binding ResetToDefaultCommand}"
                            Padding="6,4"
                            Opacity="{Binding ShouldInclude, Converter={StaticResource PinOpacityConverter}}"
                            IsHitTestVisible="{Binding ShouldInclude}"
                            ToolTip.Tip="{Binding DefaultStr, StringFormat='Reset to default ({0})'}">
                        <PathIcon Data="M17.65 6.35A8 8 0 1 0 20 12h-2a6 6 0 1 1-1.76-4.24L13 11h7V4l-2.35 2.35z"
                                  Width="12" Height="12" />
                    </Button>
                </StackPanel>
                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                           Text="{Binding Help}" TextWrapping="Wrap"
                           FontSize="11" Opacity="0.5" FontStyle="Italic"
                           Margin="0,2,0,4"
                           MaxLines="2" TextTrimming="CharacterEllipsis"
                           ToolTip.Tip="{Binding Help}" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="EditableComboBox" x:CompileBindings="False">
            <Grid ColumnDefinitions="200,*,Auto" RowDefinitions="Auto,Auto" Margin="0,2">
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{Binding Label}"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"
                           FontSize="12"
                           FontWeight="{Binding ShouldInclude, Converter={StaticResource ModifiedFontWeightConverter}}" />
                <ComboBox Grid.Row="0" Grid.Column="1"
                          ItemsSource="{Binding EnumValues}"
                          SelectedItem="{Binding SelectedEnumValue}"
                          IsEditable="True"
                          PlaceholderText="{Binding DefaultStr}"
                          Margin="8,0,0,0"
                          MinWidth="200"
                          MaxDropDownHeight="300"
                          HorizontalAlignment="Stretch"
                          GotFocus="EditableComboBox_GotFocus">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" MaxWidth="500"
                                       ToolTip.Tip="{Binding}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Spacing="2" Margin="4,0,0,0">
                    <Button Command="{Binding TogglePinCommand}"
                            Padding="6,4"
                            ToolTip.Tip="Pin to always include in script">
                        <Panel>
                            <PathIcon Data="M16,12V4H17V2H7V4H8V12L6,14V16H11.2V22H12.8V16H18V14L16,12Z"
                                      Width="12" Height="12"
                                      IsVisible="{Binding IsPinned}" />
                            <PathIcon
                                Data="M2,5.27L3.28,4L20,20.72L18.73,22L12.8,16.07V22H11.2V16H6V14L8,12V11.27L2,5.27M16,12L18,14V16H17.82L8,6.18V4H7V2H17V4H16V12Z"
                                Width="12" Height="12"
                                IsVisible="{Binding !IsPinned}"
                                Opacity="0.4" />
                        </Panel>
                    </Button>
                    <Button Command="{Binding ResetToDefaultCommand}"
                            Padding="6,4"
                            Opacity="{Binding ShouldInclude, Converter={StaticResource PinOpacityConverter}}"
                            IsHitTestVisible="{Binding ShouldInclude}"
                            ToolTip.Tip="{Binding DefaultStr, StringFormat='Reset to default ({0})'}">
                        <PathIcon Data="M17.65 6.35A8 8 0 1 0 20 12h-2a6 6 0 1 1-1.76-4.24L13 11h7V4l-2.35 2.35z"
                                  Width="12" Height="12" />
                    </Button>
                </StackPanel>
                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                           Text="{Binding Help}" TextWrapping="Wrap"
                           FontSize="11" Opacity="0.5" FontStyle="Italic"
                           Margin="0,2,0,4"
                           MaxLines="2" TextTrimming="CharacterEllipsis"
                           ToolTip.Tip="{Binding Help}" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="Numeric" x:CompileBindings="False">
            <Grid ColumnDefinitions="200,*,Auto" RowDefinitions="Auto,Auto" Margin="0,2">
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{Binding Label}"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"
                           FontSize="12"
                           FontWeight="{Binding ShouldInclude, Converter={StaticResource ModifiedFontWeightConverter}}" />
                <NumericUpDown Grid.Row="0" Grid.Column="1"
                               Value="{Binding NumericValue}"
                               Watermark="{Binding DefaultStr}"
                               Minimum="0"
                               Increment="1"
                               Margin="8,0,0,0"
                               MinWidth="200"
                               HorizontalAlignment="Stretch"
                               ShowButtonSpinner="True" />
                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Spacing="2" Margin="4,0,0,0">
                    <Button Command="{Binding TogglePinCommand}"
                            Padding="6,4"
                            ToolTip.Tip="Pin to always include in script">
                        <Panel>
                            <PathIcon Data="M16,12V4H17V2H7V4H8V12L6,14V16H11.2V22H12.8V16H18V14L16,12Z"
                                      Width="12" Height="12"
                                      IsVisible="{Binding IsPinned}" />
                            <PathIcon
                                Data="M2,5.27L3.28,4L20,20.72L18.73,22L12.8,16.07V22H11.2V16H6V14L8,12V11.27L2,5.27M16,12L18,14V16H17.82L8,6.18V4H7V2H17V4H16V12Z"
                                Width="12" Height="12"
                                IsVisible="{Binding !IsPinned}"
                                Opacity="0.4" />
                        </Panel>
                    </Button>
                    <Button Command="{Binding ResetToDefaultCommand}"
                            Padding="6,4"
                            Opacity="{Binding ShouldInclude, Converter={StaticResource PinOpacityConverter}}"
                            IsHitTestVisible="{Binding ShouldInclude}"
                            ToolTip.Tip="{Binding DefaultStr, StringFormat='Reset to default ({0})'}">
                        <PathIcon Data="M17.65 6.35A8 8 0 1 0 20 12h-2a6 6 0 1 1-1.76-4.24L13 11h7V4l-2.35 2.35z"
                                  Width="12" Height="12" />
                    </Button>
                </StackPanel>
                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                           Text="{Binding Help}" TextWrapping="Wrap"
                           FontSize="11" Opacity="0.5" FontStyle="Italic"
                           Margin="0,2,0,4"
                           MaxLines="2" TextTrimming="CharacterEllipsis"
                           ToolTip.Tip="{Binding Help}" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="Duration" x:CompileBindings="False">
            <Grid ColumnDefinitions="200,*,Auto" RowDefinitions="Auto,Auto" Margin="0,2">
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{Binding Label}"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"
                           FontSize="12"
                           FontWeight="{Binding ShouldInclude, Converter={StaticResource ModifiedFontWeightConverter}}" />
                <TimePicker Grid.Row="0" Grid.Column="1"
                            SelectedTime="{Binding DurationValue}"
                            ClockIdentifier="24HourClock"
                            UseSeconds="True"
                            MinuteIncrement="1"
                            Margin="8,0,0,0"
                            MinWidth="200"
                            HorizontalAlignment="Left" />
                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Spacing="2" Margin="4,0,0,0">
                    <Button Command="{Binding TogglePinCommand}"
                            Padding="6,4"
                            ToolTip.Tip="Pin to always include in script">
                        <Panel>
                            <PathIcon Data="M16,12V4H17V2H7V4H8V12L6,14V16H11.2V22H12.8V16H18V14L16,12Z"
                                      Width="12" Height="12"
                                      IsVisible="{Binding IsPinned}" />
                            <PathIcon
                                Data="M2,5.27L3.28,4L20,20.72L18.73,22L12.8,16.07V22H11.2V16H6V14L8,12V11.27L2,5.27M16,12L18,14V16H17.82L8,6.18V4H7V2H17V4H16V12Z"
                                Width="12" Height="12"
                                IsVisible="{Binding !IsPinned}"
                                Opacity="0.4" />
                        </Panel>
                    </Button>
                    <Button Command="{Binding ResetToDefaultCommand}"
                            Padding="6,4"
                            Opacity="{Binding ShouldInclude, Converter={StaticResource PinOpacityConverter}}"
                            IsHitTestVisible="{Binding ShouldInclude}"
                            ToolTip.Tip="{Binding DefaultStr, StringFormat='Reset to default ({0})'}">
                        <PathIcon Data="M17.65 6.35A8 8 0 1 0 20 12h-2a6 6 0 1 1-1.76-4.24L13 11h7V4l-2.35 2.35z"
                                  Width="12" Height="12" />
                    </Button>
                </StackPanel>
                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                           Text="{Binding Help}" TextWrapping="Wrap"
                           FontSize="11" Opacity="0.5" FontStyle="Italic"
                           Margin="0,2,0,4"
                           MaxLines="2" TextTrimming="CharacterEllipsis"
                           ToolTip.Tip="{Binding Help}" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="SizeSuffix" x:CompileBindings="False">
            <Grid ColumnDefinitions="200,*,Auto" RowDefinitions="Auto,Auto" Margin="0,2">
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{Binding Label}"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"
                           FontSize="12"
                           FontWeight="{Binding ShouldInclude, Converter={StaticResource ModifiedFontWeightConverter}}" />
                <Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="*,Auto" Margin="8,0,0,0">
                    <NumericUpDown Grid.Column="0"
                                   Value="{Binding SizeSuffixNumericValue}"
                                   Watermark="{Binding DefaultStr}"
                                   Minimum="0"
                                   Increment="1"
                                   ShowButtonSpinner="True"
                                   MinWidth="120"
                                   HorizontalAlignment="Stretch" />
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding SizeSuffixUnits}"
                              SelectedItem="{Binding SizeSuffixUnit}"
                              MinWidth="90"
                              Margin="4,0,0,0"
                              HorizontalAlignment="Right" />
                </Grid>
                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Spacing="2" Margin="4,0,0,0">
                    <Button Command="{Binding TogglePinCommand}"
                            Padding="6,4"
                            ToolTip.Tip="Pin to always include in script">
                        <Panel>
                            <PathIcon Data="M16,12V4H17V2H7V4H8V12L6,14V16H11.2V22H12.8V16H18V14L16,12Z"
                                      Width="12" Height="12"
                                      IsVisible="{Binding IsPinned}" />
                            <PathIcon
                                Data="M2,5.27L3.28,4L20,20.72L18.73,22L12.8,16.07V22H11.2V16H6V14L8,12V11.27L2,5.27M16,12L18,14V16H17.82L8,6.18V4H7V2H17V4H16V12Z"
                                Width="12" Height="12"
                                IsVisible="{Binding !IsPinned}"
                                Opacity="0.4" />
                        </Panel>
                    </Button>
                    <Button Command="{Binding ResetToDefaultCommand}"
                            Padding="6,4"
                            Opacity="{Binding ShouldInclude, Converter={StaticResource PinOpacityConverter}}"
                            IsHitTestVisible="{Binding ShouldInclude}"
                            ToolTip.Tip="{Binding DefaultStr, StringFormat='Reset to default ({0})'}">
                        <PathIcon Data="M17.65 6.35A8 8 0 1 0 20 12h-2a6 6 0 1 1-1.76-4.24L13 11h7V4l-2.35 2.35z"
                                  Width="12" Height="12" />
                    </Button>
                </StackPanel>
                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                           Text="{Binding Help}" TextWrapping="Wrap"
                           FontSize="11" Opacity="0.5" FontStyle="Italic"
                           Margin="0,2,0,4"
                           MaxLines="2" TextTrimming="CharacterEllipsis"
                           ToolTip.Tip="{Binding Help}" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="Text" x:CompileBindings="False">
            <Grid ColumnDefinitions="200,*,Auto" RowDefinitions="Auto,Auto,Auto" Margin="0,2">
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{Binding Label}"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"
                           IsVisible="{Binding !IsPassword}"
                           FontSize="12"
                           FontWeight="{Binding ShouldInclude, Converter={StaticResource ModifiedFontWeightConverter}}" />
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{Binding Label}"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Top"
                           Margin="0,6,0,0"
                           IsVisible="{Binding IsPassword}"
                           FontSize="12"
                           FontWeight="{Binding ShouldInclude, Converter={StaticResource ModifiedFontWeightConverter}}" />
                <Grid Grid.Row="0" Grid.Column="1" Margin="8,0,0,0">
                    <TextBox Grid.Column="0"
                             Text="{Binding Value}"
                             Watermark="{Binding DefaultStr}"
                             IsVisible="{Binding !IsPassword}"
                             HorizontalAlignment="Stretch" />

                    <StackPanel Grid.Column="0"
                                Spacing="4"
                                IsVisible="{Binding IsPassword}">
                        <Grid>
                            <TextBox
                                Text="{Binding Value}"
                                PasswordChar="•"
                                IsVisible="{Binding !IsSecretVisible}"
                                HorizontalAlignment="Stretch" />
                            <TextBox
                                Text="{Binding Value}"
                                IsVisible="{Binding IsSecretVisible}"
                                HorizontalAlignment="Stretch" />

                            <Button
                                Command="{Binding ToggleSecretVisibilityCommand}"
                                IsVisible="{Binding IsPassword}"
                                Padding="6,4"
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right"
                                ToolTip.Tip="Show or hide secret">
                                <Panel>
                                    <PathIcon
                                        Data="M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9Z"
                                        Width="12" Height="12"
                                        IsVisible="{Binding !IsSecretVisible}" />
                                    <PathIcon
                                        Data="M2,5.27L3.28,4L20,20.72L18.73,22L15.65,18.92C14.5,19.29 13.28,19.5 12,19.5C7,19.5 2.73,16.39 1,12C1.69,10.24 2.79,8.69 4.19,7.46L2,5.27M12,7A5,5 0 0,1 17,12C17,13.18 16.59,14.27 15.9,15.14L14.44,13.68C14.78,13.19 15,12.62 15,12A3,3 0 0,0 12,9C11.38,9 10.81,9.22 10.32,9.56L8.86,8.1C9.73,7.41 10.82,7 12,7M12,4.5C17,4.5 21.27,7.61 23,12C22.18,14.08 20.79,15.88 19,17.19L17.58,15.77C18.76,14.92 19.77,13.62 20.5,12C18.77,8.11 15.63,6.5 12,6.5C10.98,6.5 10,6.63 9.07,6.87L7.43,5.23C8.84,4.76 10.39,4.5 12,4.5Z"
                                        Width="12" Height="12"
                                        IsVisible="{Binding IsSecretVisible}" />
                                </Panel>
                            </Button>
                        </Grid>

                        <TextBox Text="{Binding ConfirmValue}"
                                 PasswordChar="•"
                                 IsVisible="{Binding !IsSecretVisible}"
                                 Watermark="Confirm"
                                 HorizontalAlignment="Stretch" />
                        <TextBox Text="{Binding ConfirmValue}"
                                 IsVisible="{Binding IsSecretVisible}"
                                 Watermark="Confirm"
                                 HorizontalAlignment="Stretch" />
                    </StackPanel>

                </Grid>

                <TextBlock Grid.Row="1" Grid.Column="1"
                           Text="Values do not match"
                           IsVisible="{Binding HasSecretMismatch}"
                           Foreground="IndianRed"
                           FontSize="11"
                           Margin="8,2,0,0" />
                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Spacing="2" Margin="4,0,0,0"
                            IsVisible="{Binding !IsPassword}">
                    <Button Command="{Binding TogglePinCommand}"
                            Padding="6,4"
                            ToolTip.Tip="Pin to always include in script">
                        <Panel>
                            <PathIcon Data="M16,12V4H17V2H7V4H8V12L6,14V16H11.2V22H12.8V16H18V14L16,12Z"
                                      Width="12" Height="12"
                                      IsVisible="{Binding IsPinned}" />
                            <PathIcon
                                Data="M2,5.27L3.28,4L20,20.72L18.73,22L12.8,16.07V22H11.2V16H6V14L8,12V11.27L2,5.27M16,12L18,14V16H17.82L8,6.18V4H7V2H17V4H16V12Z"
                                Width="12" Height="12"
                                IsVisible="{Binding !IsPinned}"
                                Opacity="0.4" />
                        </Panel>
                    </Button>
                    <Button Command="{Binding ResetToDefaultCommand}"
                            Padding="6,4"
                            Opacity="{Binding ShouldInclude, Converter={StaticResource PinOpacityConverter}}"
                            IsHitTestVisible="{Binding ShouldInclude}"
                            ToolTip.Tip="{Binding DefaultStr, StringFormat='Reset to default ({0})'}">
                        <PathIcon Data="M17.65 6.35A8 8 0 1 0 20 12h-2a6 6 0 1 1-1.76-4.24L13 11h7V4l-2.35 2.35z"
                                  Width="12" Height="12" />
                    </Button>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Spacing="2" Margin="4,0,0,0"
                            VerticalAlignment="Top"
                            IsVisible="{Binding IsPassword}">
                    <Button Command="{Binding TogglePinCommand}"
                            Padding="6,4"
                            ToolTip.Tip="Pin to always include in script">
                        <Panel>
                            <PathIcon Data="M16,12V4H17V2H7V4H8V12L6,14V16H11.2V22H12.8V16H18V14L16,12Z"
                                      Width="12" Height="12"
                                      IsVisible="{Binding IsPinned}" />
                            <PathIcon
                                Data="M2,5.27L3.28,4L20,20.72L18.73,22L12.8,16.07V22H11.2V16H6V14L8,12V11.27L2,5.27M16,12L18,14V16H17.82L8,6.18V4H7V2H17V4H16V12Z"
                                Width="12" Height="12"
                                IsVisible="{Binding !IsPinned}"
                                Opacity="0.4" />
                        </Panel>
                    </Button>
                    <Button Command="{Binding ResetToDefaultCommand}"
                            Padding="6,4"
                            Opacity="{Binding ShouldInclude, Converter={StaticResource PinOpacityConverter}}"
                            IsHitTestVisible="{Binding ShouldInclude}"
                            ToolTip.Tip="{Binding DefaultStr, StringFormat='Reset to default ({0})'}">
                        <PathIcon Data="M17.65 6.35A8 8 0 1 0 20 12h-2a6 6 0 1 1-1.76-4.24L13 11h7V4l-2.35 2.35z"
                                  Width="12" Height="12" />
                    </Button>
                </StackPanel>
                <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                           Text="{Binding Help}" TextWrapping="Wrap"
                           FontSize="11" Opacity="0.5" FontStyle="Italic"
                           Margin="0,2,0,4"
                           MaxLines="2" TextTrimming="CharacterEllipsis"
                           ToolTip.Tip="{Binding Help}" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="StringList" x:CompileBindings="False">
            <Grid ColumnDefinitions="200,*,Auto" RowDefinitions="Auto,Auto" Margin="0,2">
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{Binding Label}"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Top"
                           Margin="0,6,0,0"
                           FontSize="12"
                           FontWeight="{Binding ShouldInclude, Converter={StaticResource ModifiedFontWeightConverter}}" />
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,0" Spacing="4">
                    <ItemsControl ItemsSource="{Binding StringListItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="4">
                                    <TextBox Grid.Column="0"
                                             Grid.ColumnSpan="2"
                                             Text="{Binding Text}"
                                             IsVisible="{Binding !IsKeyValue}"
                                             HorizontalAlignment="Stretch" />
                                    <TextBox Grid.Column="0"
                                             Text="{Binding Key}"
                                             IsVisible="{Binding IsKeyValue}"
                                             Watermark="Key"
                                             HorizontalAlignment="Stretch" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding ItemValue}"
                                             IsVisible="{Binding IsKeyValue}"
                                             Watermark="Value"
                                             HorizontalAlignment="Stretch" />
                                    <Button Grid.Column="2"
                                            Command="{Binding RemoveCommand}"
                                            Padding="6,4"
                                            ToolTip.Tip="Remove"
                                            VerticalAlignment="Center">
                                        <PathIcon
                                            Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                                            Width="10" Height="10" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Command="{Binding AddStringListItemCommand}"
                            Padding="6,4"
                            ToolTip.Tip="Add item"
                            HorizontalAlignment="Left">
                        <PathIcon Data="M19 13H13v6h-2v-6H5v-2h6V5h2v6h6z"
                                  Width="12" Height="12" />
                    </Button>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Spacing="2" Margin="4,0,0,0"
                            VerticalAlignment="Top">
                    <Button Command="{Binding TogglePinCommand}"
                            Padding="6,4"
                            ToolTip.Tip="Pin to always include in script">
                        <Panel>
                            <PathIcon Data="M16,12V4H17V2H7V4H8V12L6,14V16H11.2V22H12.8V16H18V14L16,12Z"
                                      Width="12" Height="12"
                                      IsVisible="{Binding IsPinned}" />
                            <PathIcon
                                Data="M2,5.27L3.28,4L20,20.72L18.73,22L12.8,16.07V22H11.2V16H6V14L8,12V11.27L2,5.27M16,12L18,14V16H17.82L8,6.18V4H7V2H17V4H16V12Z"
                                Width="12" Height="12"
                                IsVisible="{Binding !IsPinned}"
                                Opacity="0.4" />
                        </Panel>
                    </Button>
                    <Button Command="{Binding ResetToDefaultCommand}"
                            Padding="6,4"
                            Opacity="{Binding ShouldInclude, Converter={StaticResource PinOpacityConverter}}"
                            IsHitTestVisible="{Binding ShouldInclude}"
                            ToolTip.Tip="{Binding DefaultStr, StringFormat='Reset to default ({0})'}">
                        <PathIcon Data="M17.65 6.35A8 8 0 1 0 20 12h-2a6 6 0 1 1-1.76-4.24L13 11h7V4l-2.35 2.35z"
                                  Width="12" Height="12" />
                    </Button>
                </StackPanel>
                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                           Text="{Binding Help}" TextWrapping="Wrap"
                           FontSize="11" Opacity="0.5" FontStyle="Italic"
                           Margin="0,2,0,4"
                           MaxLines="2" TextTrimming="CharacterEllipsis"
                           ToolTip.Tip="{Binding Help}" />
            </Grid>
        </DataTemplate>
    </Application.Resources>

    <NativeMenu.Menu>
        <NativeMenu>
            <NativeMenuItem Header="About Rclone Mount Manager" Click="AboutMenuItem_OnClick" />
            <NativeMenuItemSeparator />
            <NativeMenuItem Header="Quit Rclone Mount Manager" Gesture="Cmd+Q" Click="QuitMenuItem_OnClick" />
        </NativeMenu>
    </NativeMenu.Menu>

    <Application.DataTemplates>
        <gui:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>