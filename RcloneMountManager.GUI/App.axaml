<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="RcloneMountManager.App"
             xmlns:local="using:RcloneMountManager"
             xmlns:converters="using:RcloneMountManager.Converters"
             Name="Rclone Mount Manager"
             RequestedThemeVariant="Default">

    <Application.Resources>
        <converters:BoolToBrushConverter x:Key="AccentBorderConverter"
                                         TrueBrush="{DynamicResource SystemAccentColorDark1}"
                                         FalseBrush="Transparent"/>
        <converters:BoolToFontWeightConverter x:Key="ModifiedFontWeightConverter"/>
        <converters:EnumDescriptionConverter x:Key="EnumDescriptionConverter"/>
        <converters:BoolToOpacityConverter x:Key="PinOpacityConverter"
                                           TrueOpacity="1.0"
                                           FalseOpacity="0.3"/>

        <DataTemplate x:Key="Toggle" x:CompileBindings="False">
            <Grid ColumnDefinitions="200,*,Auto,Auto" RowDefinitions="Auto,Auto" Margin="0,2">
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="{Binding Label}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"
                               FontSize="12"
                               FontWeight="{Binding ShouldInclude, Converter={StaticResource ModifiedFontWeightConverter}}"/>
                    <ToggleSwitch Grid.Row="0" Grid.Column="1"
                                  IsChecked="{Binding BoolValue}"
                                   OnContent="Enabled" OffContent="Disabled"
                                  Margin="8,0,0,0"/>
                     <Button Grid.Row="0" Grid.Column="2"
                             Command="{Binding TogglePinCommand}"
                             Padding="6,4" Margin="0,0,0,0"
                             ToolTip.Tip="Pin to always include in script">
                         <PathIcon Data="M16 12V4h1V2H7v2h1v8l-2 2v2h5.2v6h1.6v-6H18v-2l-2-2z"
                                   Width="12" Height="12"
                                   Opacity="{Binding IsPinned, Converter={StaticResource PinOpacityConverter}}"/>
                     </Button>
                     <Button Grid.Row="0" Grid.Column="3"
                             Command="{Binding ResetToDefaultCommand}"
                             Padding="6,4" Margin="4,0,0,0"
                             IsVisible="{Binding ShouldInclude}"
                             ToolTip.Tip="{Binding DefaultStr, StringFormat='Reset to default ({0})'}">
                        <PathIcon Data="M17.65 6.35A8 8 0 1 0 20 12h-2a6 6 0 1 1-1.76-4.24L13 11h7V4l-2.35 2.35z"
                                  Width="12" Height="12"/>
                    </Button>
                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                               Text="{Binding Help}" TextWrapping="Wrap"
                               FontSize="11" Opacity="0.5" FontStyle="Italic"
                               Margin="0,2,0,4"
                               MaxLines="2" TextTrimming="CharacterEllipsis"
                               ToolTip.Tip="{Binding Help}"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ComboBox" x:CompileBindings="False">
            <Grid ColumnDefinitions="200,*,Auto,Auto" RowDefinitions="Auto,Auto" Margin="0,2">
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="{Binding Label}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"
                               FontSize="12"
                               FontWeight="{Binding ShouldInclude, Converter={StaticResource ModifiedFontWeightConverter}}"/>
                     <ComboBox Grid.Row="0" Grid.Column="1"
                               ItemsSource="{Binding EnumValues}"
                               SelectedItem="{Binding SelectedEnumValue}"
                               PlaceholderText="{Binding DefaultStr}"
                               Margin="8,0,0,0"
                               MinWidth="200"
                               MaxDropDownHeight="300"
                               HorizontalAlignment="Stretch">
                         <ComboBox.ItemTemplate>
                             <DataTemplate>
                                 <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" MaxWidth="500" ToolTip.Tip="{Binding}"/>
                             </DataTemplate>
                         </ComboBox.ItemTemplate>
                     </ComboBox>
                     <Button Grid.Row="0" Grid.Column="2"
                             Command="{Binding TogglePinCommand}"
                             Padding="6,4" Margin="0,0,0,0"
                             ToolTip.Tip="Pin to always include in script">
                         <PathIcon Data="M16 12V4h1V2H7v2h1v8l-2 2v2h5.2v6h1.6v-6H18v-2l-2-2z"
                                   Width="12" Height="12"
                                   Opacity="{Binding IsPinned, Converter={StaticResource PinOpacityConverter}}"/>
                     </Button>
                     <Button Grid.Row="0" Grid.Column="3"
                             Command="{Binding ResetToDefaultCommand}"
                             Padding="6,4" Margin="4,0,0,0"
                             IsVisible="{Binding ShouldInclude}"
                             ToolTip.Tip="{Binding DefaultStr, StringFormat='Reset to default ({0})'}">
                        <PathIcon Data="M17.65 6.35A8 8 0 1 0 20 12h-2a6 6 0 1 1-1.76-4.24L13 11h7V4l-2.35 2.35z"
                                  Width="12" Height="12"/>
                    </Button>
                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                               Text="{Binding Help}" TextWrapping="Wrap"
                               FontSize="11" Opacity="0.5" FontStyle="Italic"
                               Margin="0,2,0,4"
                               MaxLines="2" TextTrimming="CharacterEllipsis"
                               ToolTip.Tip="{Binding Help}"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="Numeric" x:CompileBindings="False">
            <Grid ColumnDefinitions="200,*,Auto,Auto" RowDefinitions="Auto,Auto" Margin="0,2">
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="{Binding Label}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"
                               FontSize="12"
                               FontWeight="{Binding ShouldInclude, Converter={StaticResource ModifiedFontWeightConverter}}"/>
                    <NumericUpDown Grid.Row="0" Grid.Column="1"
                                   Value="{Binding NumericValue}"
                                   Watermark="{Binding DefaultStr}"
                                   Minimum="0"
                                   Increment="1"
                                   Margin="8,0,0,0"
                                   MinWidth="200"
                                   HorizontalAlignment="Stretch"
                                   ShowButtonSpinner="True"/>
                     <Button Grid.Row="0" Grid.Column="2"
                             Command="{Binding TogglePinCommand}"
                             Padding="6,4" Margin="0,0,0,0"
                             ToolTip.Tip="Pin to always include in script">
                         <PathIcon Data="M16 12V4h1V2H7v2h1v8l-2 2v2h5.2v6h1.6v-6H18v-2l-2-2z"
                                   Width="12" Height="12"
                                   Opacity="{Binding IsPinned, Converter={StaticResource PinOpacityConverter}}"/>
                     </Button>
                     <Button Grid.Row="0" Grid.Column="3"
                             Command="{Binding ResetToDefaultCommand}"
                             Padding="6,4" Margin="4,0,0,0"
                             IsVisible="{Binding ShouldInclude}"
                             ToolTip.Tip="{Binding DefaultStr, StringFormat='Reset to default ({0})'}">
                        <PathIcon Data="M17.65 6.35A8 8 0 1 0 20 12h-2a6 6 0 1 1-1.76-4.24L13 11h7V4l-2.35 2.35z"
                                  Width="12" Height="12"/>
                    </Button>
                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                               Text="{Binding Help}" TextWrapping="Wrap"
                               FontSize="11" Opacity="0.5" FontStyle="Italic"
                               Margin="0,2,0,4"
                               MaxLines="2" TextTrimming="CharacterEllipsis"
                               ToolTip.Tip="{Binding Help}"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="Duration" x:CompileBindings="False">
            <Grid ColumnDefinitions="200,*,Auto,Auto" RowDefinitions="Auto,Auto" Margin="0,2">
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="{Binding Label}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"
                               FontSize="12"
                               FontWeight="{Binding ShouldInclude, Converter={StaticResource ModifiedFontWeightConverter}}"/>
                    <TimePicker Grid.Row="0" Grid.Column="1"
                                SelectedTime="{Binding DurationValue}"
                                ClockIdentifier="24HourClock"
                                UseSeconds="True"
                                MinuteIncrement="1"
                                Margin="8,0,0,0"
                                MinWidth="200"
                                HorizontalAlignment="Left"/>
                     <Button Grid.Row="0" Grid.Column="2"
                             Command="{Binding TogglePinCommand}"
                             Padding="6,4" Margin="0,0,0,0"
                             ToolTip.Tip="Pin to always include in script">
                         <PathIcon Data="M16 12V4h1V2H7v2h1v8l-2 2v2h5.2v6h1.6v-6H18v-2l-2-2z"
                                   Width="12" Height="12"
                                   Opacity="{Binding IsPinned, Converter={StaticResource PinOpacityConverter}}"/>
                     </Button>
                     <Button Grid.Row="0" Grid.Column="3"
                             Command="{Binding ResetToDefaultCommand}"
                             Padding="6,4" Margin="4,0,0,0"
                             IsVisible="{Binding ShouldInclude}"
                             ToolTip.Tip="{Binding DefaultStr, StringFormat='Reset to default ({0})'}">
                        <PathIcon Data="M17.65 6.35A8 8 0 1 0 20 12h-2a6 6 0 1 1-1.76-4.24L13 11h7V4l-2.35 2.35z"
                                  Width="12" Height="12"/>
                    </Button>
                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                               Text="{Binding Help}" TextWrapping="Wrap"
                               FontSize="11" Opacity="0.5" FontStyle="Italic"
                               Margin="0,2,0,4"
                               MaxLines="2" TextTrimming="CharacterEllipsis"
                               ToolTip.Tip="{Binding Help}"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="SizeSuffix" x:CompileBindings="False">
            <Grid ColumnDefinitions="200,*,Auto,Auto" RowDefinitions="Auto,Auto" Margin="0,2">
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="{Binding Label}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"
                               FontSize="12"
                               FontWeight="{Binding ShouldInclude, Converter={StaticResource ModifiedFontWeightConverter}}"/>
                    <Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="*,Auto" Margin="8,0,0,0">
                        <NumericUpDown Grid.Column="0"
                                       Value="{Binding SizeSuffixNumericValue}"
                                       Watermark="{Binding DefaultStr}"
                                       Minimum="0"
                                       Increment="1"
                                       ShowButtonSpinner="True"
                                       MinWidth="120"
                                       HorizontalAlignment="Stretch"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding SizeSuffixUnits}"
                                  SelectedItem="{Binding SizeSuffixUnit}"
                                  MinWidth="90"
                                  Margin="4,0,0,0"
                                  HorizontalAlignment="Right"/>
                    </Grid>
                     <Button Grid.Row="0" Grid.Column="2"
                             Command="{Binding TogglePinCommand}"
                             Padding="6,4" Margin="0,0,0,0"
                             ToolTip.Tip="Pin to always include in script">
                         <PathIcon Data="M16 12V4h1V2H7v2h1v8l-2 2v2h5.2v6h1.6v-6H18v-2l-2-2z"
                                   Width="12" Height="12"
                                   Opacity="{Binding IsPinned, Converter={StaticResource PinOpacityConverter}}"/>
                     </Button>
                     <Button Grid.Row="0" Grid.Column="3"
                             Command="{Binding ResetToDefaultCommand}"
                             Padding="6,4" Margin="4,0,0,0"
                             IsVisible="{Binding ShouldInclude}"
                             ToolTip.Tip="{Binding DefaultStr, StringFormat='Reset to default ({0})'}">
                        <PathIcon Data="M17.65 6.35A8 8 0 1 0 20 12h-2a6 6 0 1 1-1.76-4.24L13 11h7V4l-2.35 2.35z"
                                  Width="12" Height="12"/>
                    </Button>
                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                               Text="{Binding Help}" TextWrapping="Wrap"
                               FontSize="11" Opacity="0.5" FontStyle="Italic"
                               Margin="0,2,0,4"
                               MaxLines="2" TextTrimming="CharacterEllipsis"
                               ToolTip.Tip="{Binding Help}"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="Text" x:CompileBindings="False">
            <Grid ColumnDefinitions="200,*,Auto,Auto" RowDefinitions="Auto,Auto" Margin="0,2">
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="{Binding Label}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"
                               FontSize="12"
                               FontWeight="{Binding ShouldInclude, Converter={StaticResource ModifiedFontWeightConverter}}"/>
                    <TextBox Grid.Row="0" Grid.Column="1"
                              Text="{Binding Value}"
                              Watermark="{Binding DefaultStr}"
                              Margin="8,0,0,0"
                              HorizontalAlignment="Stretch"/>
                     <Button Grid.Row="0" Grid.Column="2"
                             Command="{Binding TogglePinCommand}"
                             Padding="6,4" Margin="0,0,0,0"
                             ToolTip.Tip="Pin to always include in script">
                         <PathIcon Data="M16 12V4h1V2H7v2h1v8l-2 2v2h5.2v6h1.6v-6H18v-2l-2-2z"
                                   Width="12" Height="12"
                                   Opacity="{Binding IsPinned, Converter={StaticResource PinOpacityConverter}}"/>
                     </Button>
                     <Button Grid.Row="0" Grid.Column="3"
                             Command="{Binding ResetToDefaultCommand}"
                             Padding="6,4" Margin="4,0,0,0"
                             IsVisible="{Binding ShouldInclude}"
                             ToolTip.Tip="{Binding DefaultStr, StringFormat='Reset to default ({0})'}">
                        <PathIcon Data="M17.65 6.35A8 8 0 1 0 20 12h-2a6 6 0 1 1-1.76-4.24L13 11h7V4l-2.35 2.35z"
                                  Width="12" Height="12"/>
                    </Button>
                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                               Text="{Binding Help}" TextWrapping="Wrap"
                               FontSize="11" Opacity="0.5" FontStyle="Italic"
                               Margin="0,2,0,4"
                               MaxLines="2" TextTrimming="CharacterEllipsis"
                               ToolTip.Tip="{Binding Help}"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="StringList" x:CompileBindings="False">
            <Grid ColumnDefinitions="200,*,Auto,Auto" RowDefinitions="Auto,Auto" Margin="0,2">
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="{Binding Label}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Top"
                               Margin="0,6,0,0"
                               FontSize="12"
                               FontWeight="{Binding ShouldInclude, Converter={StaticResource ModifiedFontWeightConverter}}"/>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,0" Spacing="4">
                        <ItemsControl ItemsSource="{Binding StringListItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="4">
                                        <TextBox Grid.Column="0"
                                                 Grid.ColumnSpan="2"
                                                 Text="{Binding Text}"
                                                 IsVisible="{Binding !IsKeyValue}"
                                                 HorizontalAlignment="Stretch"/>
                                        <TextBox Grid.Column="0"
                                                 Text="{Binding Key}"
                                                 IsVisible="{Binding IsKeyValue}"
                                                 Watermark="Key"
                                                 HorizontalAlignment="Stretch"/>
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding ItemValue}"
                                                 IsVisible="{Binding IsKeyValue}"
                                                 Watermark="Value"
                                                 HorizontalAlignment="Stretch"/>
                                        <Button Grid.Column="2"
                                                Command="{Binding RemoveCommand}"
                                                Padding="6,4"
                                                ToolTip.Tip="Remove"
                                                VerticalAlignment="Center">
                                            <PathIcon Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                                                      Width="10" Height="10"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Command="{Binding AddStringListItemCommand}"
                                Padding="6,4"
                                ToolTip.Tip="Add item"
                                HorizontalAlignment="Left">
                            <PathIcon Data="M19 13H13v6h-2v-6H5v-2h6V5h2v6h6z"
                                      Width="12" Height="12"/>
                        </Button>
                    </StackPanel>
                     <Button Grid.Row="0" Grid.Column="2"
                             Command="{Binding TogglePinCommand}"
                             Padding="6,4" Margin="0,0,0,0"
                             VerticalAlignment="Top"
                             ToolTip.Tip="Pin to always include in script">
                         <PathIcon Data="M16 12V4h1V2H7v2h1v8l-2 2v2h5.2v6h1.6v-6H18v-2l-2-2z"
                                   Width="12" Height="12"
                                   Opacity="{Binding IsPinned, Converter={StaticResource PinOpacityConverter}}"/>
                     </Button>
                     <Button Grid.Row="0" Grid.Column="3"
                             Command="{Binding ResetToDefaultCommand}"
                             Padding="6,4" Margin="4,0,0,0"
                             VerticalAlignment="Top"
                             IsVisible="{Binding ShouldInclude}"
                             ToolTip.Tip="{Binding DefaultStr, StringFormat='Reset to default ({0})'}">
                        <PathIcon Data="M17.65 6.35A8 8 0 1 0 20 12h-2a6 6 0 1 1-1.76-4.24L13 11h7V4l-2.35 2.35z"
                                  Width="12" Height="12"/>
                    </Button>
                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                               Text="{Binding Help}" TextWrapping="Wrap"
                               FontSize="11" Opacity="0.5" FontStyle="Italic"
                               Margin="0,2,0,4"
                               MaxLines="2" TextTrimming="CharacterEllipsis"
                               ToolTip.Tip="{Binding Help}"/>
            </Grid>
        </DataTemplate>
    </Application.Resources>

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>
